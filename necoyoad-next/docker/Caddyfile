{
	# Global FrankenPHP options
	order php_server before file_server
}

# Necoyoad — Laravel 11 on FrankenPHP
# All requests route through public/index.php (Laravel's front controller).
# Static assets in public/ (css, js, images) are served directly by Caddy.

:80 {
	# Laravel's public directory is the document root
	root * /var/www/html/public

	# Enable compression
	encode zstd gzip

	# Serve static files first (css, js, images), then fall through to PHP
	file_server

	# Route everything else through Laravel's index.php (front controller)
	php_server {
		root /var/www/html/public
		# Laravel's index.php handles all routing including 404s
		index index.php
		resolve_root_symlinks
	}

	# Security: block dotfiles (except .well-known for Let's Encrypt etc.)
	@dotfiles path_regexp \/\.(?!well-known)
	respond @dotfiles 404

	# Access logs to stdout (docker logs)
	log {
		output stdout
		format console
	}
}
