# New Necoyoad — Environment Configuration
# Copy to .env and adjust values

APP_NAME="New Necoyoad"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Database (MySQL 8 InnoDB)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=necoyoad_next
DB_USERNAME=necoyoad
DB_PASSWORD=secret

# Redis (cache, session, queue)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue (for campaign sending, bounce processing)
# Uses redis in production; sync runs jobs inline during dev/seeding
QUEUE_CONNECTION=sync

# Session (file is most robust for dev; switch to redis for production)
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache (file is most robust for dev; switch to redis for production)
CACHE_STORE=file

# Filesystem
FILESYSTEM_DISK=local

# Mail (for campaign sending + transactional emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@necoyoad.com"
MAIL_FROM_NAME="${APP_NAME}"

# Filament Admin Panel
FILAMENT_PATH=admin

# Multi-store defaults
DEFAULT_STORE_ID=0
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD

# Widget engine
WIDGET_CACHE_TTL=300
