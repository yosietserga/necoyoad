# New Necoyoad — Environment Configuration
# Copy to .env and adjust values

APP_NAME="New Necoyoad"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Database (MySQL 8 InnoDB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=necoyoad_next
DB_USERNAME=root
DB_PASSWORD=

# Redis (cache, session, queue)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue (for campaign sending, bounce processing)
QUEUE_CONNECTION=redis

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Cache
CACHE_STORE=redis

# Filesystem
FILESYSTEM_DISK=local

# Mail (for campaign sending + transactional emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@necoyoad.com"
MAIL_FROM_NAME="${APP_NAME}"

# Filament Admin Panel
FILAMENT_PATH=admin

# Multi-store defaults
DEFAULT_STORE_ID=0
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD

# Widget engine
WIDGET_CACHE_TTL=300
